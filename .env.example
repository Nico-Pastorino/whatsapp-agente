NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
NEXT_PUBLIC_DEMO_WHATSAPP_URL=https://wa.me/5491100000000
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
APP_SESSION_SECRET=cambia-este-secreto-largo

OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
# Modelo del paso de RESPUESTA al cliente (mayor precisión). Si se deja vacío usa OPENAI_MODEL.
# Recomendado para producción: gpt-4o (o gpt-4.1). Sólo encarece la respuesta, no el análisis.
AI_REPLY_MODEL=
# Modelo del paso de ANÁLISIS interno (JSON de intención). Conviene barato. Vacío = OPENAI_MODEL.
AI_ANALYSIS_MODEL=
# Cuántos productos se TRAEN de la base para armar el contexto de IA (default 400, máx 2000).
# Antes era 50 fijo y dejaba ciegos a catálogos grandes (plan Pro).
CATALOG_PROMPT_FETCH_LIMIT=400
# Cuántos productos "regulares" se MANDAN al modelo tras la selección por relevancia (default 40, máx 120).
CATALOG_PROMPT_MAX_ITEMS=40

NEXT_PUBLIC_APP_URL=http://localhost:3000
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=...

# Soporte (opcionales — si faltan, los botones quedan deshabilitados)
NEXT_PUBLIC_SUPPORT_WHATSAPP_URL=https://wa.me/549XXXXXXXXXX?text=Hola%2C%20necesito%20ayuda%20con%20Atend%C3%A9
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@atende.app

BUSINESS_ID=
WORKER_INSTANCE_NAME=main
WHATSAPP_PROVIDER=baileys

BAILEYS_AUTH_BASE_PATH=./auth
