NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
OPENAI_API_KEY=your_openai_key
# Modelo base / fallback. Barato. Se usa para análisis y como respaldo.
OPENAI_MODEL=gpt-4o-mini
# Modelo del paso de RESPUESTA al cliente. Es el que más impacta en precisión
# y en seguir reglas duras (ej: "plan canje desde iPhone 13", no inventar).
# RECOMENDADO en producción: un modelo fuerte (ej: gpt-4o). Vacío = usa OPENAI_MODEL.
# Cambiar SOLO esto NO encarece el análisis interno (sigue en mini).
AI_REPLY_MODEL=gpt-4o
# Modelo del paso de ANÁLISIS interno (JSON de intención). Conviene barato.
# Vacío = usa OPENAI_MODEL (gpt-4o-mini). No hace falta tocarlo.
AI_ANALYSIS_MODEL=

BUSINESS_ID=your_business_id_uuid
WORKER_INSTANCE_NAME=main
WHATSAPP_PROVIDER=baileys
BAILEYS_AUTH_BASE_PATH=/data/baileys-auth
